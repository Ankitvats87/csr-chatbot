#################################
# OPENAI (embeddings + optional chat fallback)
#################################
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

#################################
# OPENROUTER (primary chat provider for Phase 1)
#################################
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FALLBACK_TO_OPENAI=true
# Optional: identify your app to OpenRouter (helps with rate limits + analytics)
OPENROUTER_REFERER=https://srv988340.hstgr.cloud
OPENROUTER_APP_TITLE=Spark63 CSR Bot

#################################
# PINECONE
#################################
PINECONE_API_KEY=
PINECONE_INDEX_NAME=spark-csr
PINECONE_NAMESPACE=knowledgebase
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

#################################
# TELEGRAM
#################################
TELEGRAM_BOT_TOKEN=
# A long random string. Telegram echoes this back as X-Telegram-Bot-Api-Secret-Token
# on every webhook hit. If left blank, scripts/setup_webhook.sh will generate one.
TELEGRAM_WEBHOOK_SECRET=

#################################
# ACCESS CONTROL
# In Phase 2, the bot is admin-gated.
#  - ADMIN_CHAT_IDS: comma-separated admins (always allowed). Get yours via @userinfobot.
#  - ALLOWED_CHAT_IDS: optional static allowlist (in addition to the dynamic DB allowlist).
# If BOTH lists are empty, the bot operates in "first /start auto-claims admin" bootstrap mode.
#################################
ADMIN_CHAT_IDS=
ALLOWED_CHAT_IDS=

#################################
# GOOGLE DRIVE (Phase 2 ingestion)
# Use OAuth2 with a refresh token (NOT a service account, since the folder is in a personal Drive).
# How to generate these: see README "Generating Google Drive credentials".
#################################
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
# Poll cadence in seconds (default 120 = 2 min)
INGESTION_POLL_INTERVAL_SECONDS=120
# Files larger than this are skipped (in MB). Default 50.
INGESTION_MAX_FILE_MB=50
# LlamaIndex / LlamaParse Cloud API Key (starts with llx-)
LLAMA_CLOUD_API_KEY=

#################################
# MEMORY
# MEMORY_WINDOW = number of recent EXCHANGES (user+assistant pairs) the bot
# replays back into each new prompt. 5 means the bot remembers the last 5
# back-and-forth turns per chat_id.
#################################
MEMORY_WINDOW=5

#################################
# RETRIEVAL
#################################
TOP_K=5
SIMILARITY_THRESHOLD=0.75
CHUNK_SIZE=600
CHUNK_OVERLAP=50

#################################
# RAG VERSION
# v1 = V1 pipeline (knowledgebase namespace) — production default
# v2 = V2 pipeline (csr_v2_enriched + csr_project_master namespaces)
#      Requires csr_v2_enriched and csr_project_master to be populated
#      first by running: python -u scripts/ingest_v2.py --all
#################################
RAG_VERSION=v1

#################################
# INTELLIGENCE LAYER + HYBRID RETRIEVAL
# ENABLE_INTELLIGENCE_LAYER: query planner + entity routing + dual-pass generation
# ENABLE_HYBRID_RETRIEVAL : BM25 lexical + vector + Reciprocal Rank Fusion.
#   Requires data/v2_chunk_store.json — build once with:
#     python -u scripts/build_chunk_store.py
# ENABLE_RERANKER         : LLM listwise reranker (1 extra cheap LLM call/query)
#################################
ENABLE_INTELLIGENCE_LAYER=false
ENABLE_HYBRID_RETRIEVAL=false
ENABLE_RERANKER=false
HYBRID_BM25_TOP_K=25
RERANK_CANDIDATES=30
CONTEXT_MAX_CHUNKS=24
CHUNK_STORE_PATH=data/v2_chunk_store.json
LLM_MAX_TOKENS=1600

#################################
# APPLICATION
#################################
LOG_LEVEL=INFO
APP_PORT=8000
SQLITE_PATH=/app/data/sqlite/app.db

#################################
# ADMIN WEB DASHBOARD
#################################
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

#################################
# DEPLOYMENT (used by Caddy + setup_webhook.sh)
#################################
PUBLIC_DOMAIN=srv988340.hstgr.cloud
WEBHOOK_PATH=/webhook/telegram
# Email used by Let's Encrypt for cert renewal notices
ACME_EMAIL=
